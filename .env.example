# Copy this to .env and fill in your values
# cp .env.example .env

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
CLAUDE_MODEL=claude-3-sonnet-20240229
AGENT_MAX_ITERATIONS=10
AGENT_TEMPERATURE=0.1

API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

YFINANCE_TIMEOUT=10
NEWS_MAX_ARTICLES=5
SEC_MAX_FILINGS=3
